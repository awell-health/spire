# Stage 1: build the Spire binaries used by the worker image.
FROM golang:1.26-alpine AS build

ARG BEADS_VERSION=v0.61.0

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/spire ./cmd/spire/ && \
    CGO_ENABLED=0 GOOS=linux go build -o /out/spire-sidecar ./cmd/spire-sidecar/ && \
    CGO_ENABLED=0 GOOS=linux go build -o /out/spire-artificer ./cmd/spire-artificer/

# Build bd (beads) from source
WORKDIR /beads
RUN apk add --no-cache git \
    && git clone --depth 1 --branch "${BEADS_VERSION}" https://github.com/steveyegge/beads.git . \
    && CGO_ENABLED=0 GOOS=linux go build -o /out/bd ./cmd/bd/

# Stage 2: install Dolt.
FROM alpine:3.20 AS tools

ARG DOLT_VERSION=latest

RUN apk add --no-cache bash curl
RUN if [ "$DOLT_VERSION" = "latest" ]; then \
        curl -L https://github.com/dolthub/dolt/releases/latest/download/install.sh | bash; \
    else \
        curl -L "https://github.com/dolthub/dolt/releases/download/${DOLT_VERSION}/install.sh" | bash; \
    fi

# Stage 3: worker runtime.
FROM alpine:3.20

ARG INSTALL_CLAUDE=1
ARG CLAUDE_NPM_PACKAGE=@anthropic-ai/claude-code

ARG GO_VERSION=1.26.1

RUN apk add --no-cache \
    bash \
    ca-certificates \
    coreutils \
    curl \
    git \
    github-cli \
    jq \
    nodejs \
    npm \
    openssh-client \
    py3-pip \
    python3

# Install Go from official tarball (Alpine's package is too old)
RUN ARCH=$(uname -m | sed 's/aarch64/arm64/' | sed 's/x86_64/amd64/') && \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${ARCH}.tar.gz" | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:${PATH}"

COPY --from=build /out/spire /usr/local/bin/spire
COPY --from=build /out/spire-sidecar /usr/local/bin/spire-sidecar
COPY --from=build /out/spire-artificer /usr/local/bin/spire-artificer
COPY --from=build /out/bd /usr/local/bin/bd
COPY --from=tools /usr/local/bin/dolt /usr/local/bin/dolt

RUN if [ "$INSTALL_CLAUDE" = "1" ]; then npm install -g "${CLAUDE_NPM_PACKAGE}"; fi

COPY agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh
RUN chmod +x /usr/local/bin/agent-entrypoint.sh && \
    mkdir -p /workspace /data /comms

# Pre-initialize beads database snapshot with DoltHub data baked in.
# Pass --build-arg DOLT_CREDS_JWK=<base64-jwk> to include auth for clone.
# Without creds, creates an empty but functional beads DB.
ARG DOLTHUB_REMOTE=https://doltremoteapi.dolthub.com/awell/spire
ARG DOLT_CREDS_JWK=""

RUN mkdir -p /beads-snapshot && cd /beads-snapshot && git init -q && \
    git config user.name "wizard" && \
    git config user.email "wizard@spire.local" && \
    if [ -n "$DOLT_CREDS_JWK" ]; then \
        mkdir -p /root/.dolt/creds && \
        echo "$DOLT_CREDS_JWK" | base64 -d > /root/.dolt/creds/build.jwk && \
        KEY_ID=$(basename /root/.dolt/creds/build.jwk .jwk) && \
        dolt config --global --set user.creds "$KEY_ID" 2>/dev/null; \
        mkdir -p .beads/dolt && \
        dolt clone "$DOLTHUB_REMOTE" .beads/dolt/spi 2>&1 || true; \
    fi && \
    BEADS_DOLT_SERVER_PORT=3307 bd init --force --prefix spi && \
    bd dolt set port 3307 && \
    echo '{"prefix":"spi-","path":"."}' >> .beads/routes.jsonl && \
    rm -f .beads/dolt-server.lock .beads/dolt-server.pid .beads/dolt-server.port && \
    rm -rf /root/.dolt/creds

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/agent-entrypoint.sh"]
