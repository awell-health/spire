# Operator Makefile — RBAC/CRD manifest generation and drift guards.
#
# The single source of truth for the operator's ClusterRole is the set
# of +kubebuilder:rbac: markers embedded in controllers/*.go. `make
# manifests` runs controller-gen to regenerate config/rbac/role.yaml
# from those markers. `make verify-rbac` runs `make manifests` and then
# fails if git sees a diff — that fires whenever a marker is added/
# removed/edited without regenerating, or when config/rbac/role.yaml
# is hand-edited. The apprentice validation pipeline invokes
# verify-rbac (see ../spire.yaml) so drift is caught before a PR
# lands.
#
# The parity check between this file and the chart's operator
# ClusterRole lives in scripts/verify-rbac-parity.sh at the repo root
# and is a separate step in the validation pipeline.

CONTROLLER_GEN ?= controller-gen
CONTROLLER_GEN_VERSION ?= v0.13.0

# manifests regenerates config/rbac/role.yaml from the
# +kubebuilder:rbac markers in controllers/*.go. Idempotent: re-running
# with no marker changes leaves the file byte-for-byte identical.
#
# controller-gen v0.13.0 emits the RBAC role without the kubebuilder
# "Code generated" header comment, so we prepend it here. Readers
# scanning config/rbac/role.yaml get a clear signal that hand-edits
# will be overwritten on the next `make manifests`.
.PHONY: manifests
manifests: controller-gen
	$(CONTROLLER_GEN) rbac:roleName=spire-operator paths="./..." output:rbac:artifacts:config=config/rbac
	@if [ -f config/rbac/role.yaml ] && ! head -n1 config/rbac/role.yaml | grep -q "Code generated"; then \
	  tmp=$$(mktemp); \
	  printf '# Code generated by controller-gen. DO NOT EDIT.\n' > $$tmp; \
	  cat config/rbac/role.yaml >> $$tmp; \
	  mv $$tmp config/rbac/role.yaml; \
	fi

# verify-rbac regenerates and fails if git sees a diff under
# config/rbac. The role.yaml file is checked in so apprentices can
# detect drift locally without having to diff against main. Pairs with
# verify-rbac-parity at the repo root, which compares this generated
# role against the helm chart's hand-maintained ClusterRole.
.PHONY: verify-rbac
verify-rbac: manifests
	@git diff --exit-code config/rbac || { \
	  echo "ERROR: config/rbac/role.yaml is out of sync with +kubebuilder:rbac markers."; \
	  echo "Run 'make manifests' in operator/ and commit the result."; \
	  exit 1; }

# controller-gen resolves the controller-gen binary. Prefers a binary
# already on PATH; otherwise `go install` into $(go env GOBIN) so CI
# and apprentice environments get the pinned version without network
# at manifests time.
.PHONY: controller-gen
controller-gen:
	@command -v $(CONTROLLER_GEN) >/dev/null 2>&1 || { \
	  echo "installing sigs.k8s.io/controller-tools/cmd/controller-gen@$(CONTROLLER_GEN_VERSION)"; \
	  GOBIN=$$(go env GOPATH)/bin go install sigs.k8s.io/controller-tools/cmd/controller-gen@$(CONTROLLER_GEN_VERSION); \
	}
