# Spire Environment Variables
#
# For local development, credentials are managed automatically:
#   spire connect linear    → stores token in system keychain
#   setup.sh                → sets SPIRE_IDENTITY and Dolt server vars
#
# These env vars are overrides for CI/automation where keychains aren't available.
# Copy to .env.local and fill in values as needed.

# ── Spire identity ──────────────────────────────────────
# Per-repo agent identity (set automatically by setup.sh)
# SPIRE_IDENTITY=hub

# ── Linear integration (optional) ──────────────────────
# Primary method: spire connect linear (uses system keychain)
# These override keychain values for CI/automation:
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=<uuid>
# LINEAR_PROJECT_ID=<uuid>
# LINEAR_WEBHOOK_SECRET=<secret>

# ── DoltHub (optional, for remote sync) ────────────────
# DOLTHUB_API_TOKEN=<token>
# DOLTHUB_OWNER=<org>
# DOLTHUB_DATABASE=<db>

# ── Dolt server ────────────────────────────────────────
# Set automatically by setup.sh
# BEADS_DOLT_SERVER_HOST=127.0.0.1
# BEADS_DOLT_SERVER_PORT=3307
# BEADS_DOLT_SERVER_MODE=1
# BEADS_DOLT_AUTO_START=0
