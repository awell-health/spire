# Spire Environment Variables
# Copy to .env.local and fill in your values

# ── Spire identity ──────────────────────────────────────
# Per-repo agent identity (set automatically by setup.sh / spire init)
# SPIRE_IDENTITY=hub

# ── Linear integration (optional) ──────────────────────
# Set up via: spire connect linear
# Or manually:
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=<uuid>
# LINEAR_PROJECT_ID=<uuid>
# LINEAR_WEBHOOK_SECRET=<secret>

# ── DoltHub (optional, for remote sync) ────────────────
# DOLTHUB_API_TOKEN=<token>
# DOLTHUB_OWNER=<org>
# DOLTHUB_DATABASE=<db>

# ── Dolt server ────────────────────────────────────────
# Set automatically by setup.sh / spire init
# BEADS_DOLT_SERVER_HOST=127.0.0.1
# BEADS_DOLT_SERVER_PORT=3307
# BEADS_DOLT_SERVER_MODE=1
# BEADS_DOLT_AUTO_START=0
