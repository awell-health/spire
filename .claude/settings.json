    "PostCompact": [
      {
        "hooks": [
          {
            "command": ".claude/spire-hook.sh",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": ".claude/spire-hook.sh",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": ".claude/spire-hook.sh",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}
